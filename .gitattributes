# The Unicode tables are generated by 3PyScheme/tools/gen_cpp_unicode_tables.scm,
# which always writes LF.  Pin LF so a fresh checkout still matches the
# generator's output byte-for-byte (re-running it then yields no diff),
# regardless of the user's core.autocrlf setting.
src/unicode_tables.h    text eol=lf
src/unicode_tables.cpp  text eol=lf

# Pre-push hook scripts must stay LF or sh (git-bash) breaks on CR.
hooks/pre-push   text eol=lf
hooks/install.sh text eol=lf
